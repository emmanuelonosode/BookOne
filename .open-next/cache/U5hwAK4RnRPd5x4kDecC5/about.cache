[\"$\",\"div\",null,{\"className\":\"my-20\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-semibold text-zinc-900  mb-4\",\"children\":\"Our Mission & Vision\"}],[\"$\",\"p\",null,{\"className\":\"mb-4\",\"children\":[[\"$\",\"strong\",null,{\"children\":\"Mission:\"}],\"Mission: At BookOne, our mission is to cultivate a vibrant, inclusive, and accessible global reading community. We strive to connect readers with books that inspire, challenge, and entertain, while empowering authors to reach new audiences and share their unique voices.\"]}],[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Vision:\"}],\" To become the go-to agency for forward-thinking brands looking to build online success through elegant design, reliable development, and strategic digital transformation.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"mb-20\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold text-primary mb-4\",\"children\":\"The Story Behind BookOne\"}],[\"$\",\"p\",null,{\"children\":[\"BookOne was born from a simple yet profound realization: in an increasingly digital world, the joy of reading and the camaraderie of book clubs were becoming fragmented. Our founder, an avid reader frustrated by scattered recommendations and isolated discussions, dreamed of a unified platform. A place where book lovers could not only discover their next favorite read but also connect with like-minded individuals, join insightful conversations, and celebrate the shared experience of storytelling.\",[\"$\",\"br\",null,{}],[\"$\",\"br\",null,{}],\"From humble beginnings as a passion project, BookOne has grown into a thriving hub, built on the principles of community, discovery, and respect for the written word. Every feature, every design choice, is made with our users in mind, ensuring a seamless and enriching experience for everyone who walks through our digital doors.\"]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold text-primary mb-8\",\"children\":\"Meet Our Team\"}],[\"$\",\"div\",null,{\"className\":\"grid gap-10 grid-cols-1 md:grid-cols-2 lg:grid-cols-3\",\"children\":[[\"$\",\"div\",null,{\"className\":\"p-6 bg-light rounded-xl shadow\",\"children\":[[\"$\",\"$L6\",null,{\"src\":\"https://randomuser.me/api/portraits/men/75.jpg\",\"width\":80,\"height\":80,\"alt\":\"CEO\",\"className\":\"rounded-full mb-4\"}],[\"$\",\"h3\",null,{\"className\":\"font-semibold text-lg text-primary\",\"children\":\"Emmanuel Onosode\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-600 mb-2\",\"children\":\"Chief Executive Officer\"}],[\"$\",\"p\",null,{\"children\":\"Emmanuel leads BookOne with a strong vision for digital transformation and creativity. With a background in tech startups and systems development, he ensures every project is purpose-driven.\"}]]}],[\"$\",\"div\",null,{\"className\":\"p-6 bg-light rounded-xl shadow\",\"children\":[[\"$\",\"$L6\",null,{\"src\":\"https://randomuser.me/api/portraits/men/45.jpg\",\"width\":80,\"height\":80,\"alt\":\"Frontend Developer\",\"className\":\"rounded-full mb-4\"}],[\"$\",\"h3\",null,{\"className\":\"font-semibold text-lg text-primary\",\"children\":\"David Johnson\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-600 mb-2\",\"children\":\"Lead Frontend Developer\"}],[\"$\",\"p\",null,{\"children\":\"David crafts seamless interfaces and responsive layouts. He specializes in modern JavaScript frameworks, especially React and Next.js, ensuring optimal user experience across all platforms.\"}]]}],[\"$\",\"div\",null,{\"className\":\"p-6 bg-light rounded-xl shadow\",\"children\":[[\"$\",\"$L6\",null,{\"src\":\"https://randomuser.me/api/portraits/women/60.jpg\",\"width\":80,\"height\":80,\"alt\":\"Web Designer\",\"className\":\"rounded-full mb-4\"}],[\"$\",\"h3\",null,{\"className\":\"font-semibold text-lg text-primary\",\"children\":\"Lisa Adekunle\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-600 mb-2\",\"children\":\"UI/UX Designer\"}],[\"$\",\"p\",null,{\"children\":\"Lisa brings creativity and clarity to every design. She's passionate about accessible layouts and elegant interactions that tell a story while serving user needs.\"}]]}],[\"$\",\"div\",null,{\"className\":\"p-6 bg-light rounded-xl shadow\",\"children\":[[\"$\",\"$L6\",null,{\"src\":\"https://randomuser.me/api/portraits/women/25.jpg\",\"width\":80,\"height\":80,\"alt\":\"Web Designer\",\"className\":\"rounded-full mb-4\"}],[\"$\",\"h3\",null,{\"className\":\"font-semibold text-lg text-primary\",\"children\":\"Tosin Bello\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-600 mb-2\",\"children\":\"Visual Designer\"}],[\"$\",\"p\",null,{\"children\":\"Tosin specializes in branding and typography. She ensures that every visual element reinforces the BookOne identity and resonates with our client’s audience.\"}]]}]]}]]}]]}],[\"$\",\"$L7\",null,{\"children\":\"$L8\"}],null,[\"$\",\"$L9\",null,{\"children\":[\"$La\",\"$Lb\",[\"$\",\"$Lc\",null,{\"promise\":\"$@d\"}]]}]]}],{},null,false]},null,false]},null,false],[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$1\",\"UEIZ2BJ_z8gQfliSsxD6Y\",{\"children\":[[\"$\",\"$Le\",null,{\"children\":\"$Lf\"}],null]}],null]}],false]],\"m\":\"$undefined\",\"G\":[\"$10\",\"$undefined\"],\"s\":false,\"S\":true}\n11:\"$Sreact.suspense\"\n12:I[4911,[],\"AsyncMetadata\"]\n8:[\"$\",\"$11\",null,{\"fallback\":null,\"children\":[\"$\",\"$L12\",null,{\"promise\":\"$@13\"}]}]\nb:null\nf:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\na:null\n13:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"About | BookOne\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Learn about BookOne’s mission, story, and team behind our web design & development agency.\"}],[\"$\",\"link\",\"2\",{\"rel\":\"manifest\",\"href\":\"/manifest.webmanifest\",\"crossOri